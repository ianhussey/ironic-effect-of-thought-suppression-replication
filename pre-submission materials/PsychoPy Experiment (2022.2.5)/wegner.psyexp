        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="myClock.reset();&amp;#10;oldTime = 0;&amp;#10;text.text = items.pop();&amp;#10;psychoJS.experiment.addData(&quot;Word&quot;, text.text);&amp;#10;psychoJS.experiment.addData(&quot;Count&quot;, thisCount);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="myClock.reset()&amp;#10;oldTime=0&amp;#10;text.text=items.pop()&amp;#10;thisExp.addData('Word',text.text)&amp;#10;thisExp.addData('Count',thisCount)&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="timeLeft=math.ceil(thisCount-myClock.getTime())&amp;#10;if timeLeft != oldTime:&amp;#10;    text_clock.text=str(timeLeft)&amp;#10;    oldTime = timeLeft&amp;#10;if timeLeft &lt;= 0:&amp;#10;    continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="timeLeft = Math.ceil((thisCount - myClock.getTime()));&amp;#10;if ((timeLeft !== oldTime)) {&amp;#10;    text_clock.text = timeLeft.toString();&amp;#10;    oldTime = timeLeft;&amp;#10;}&amp;#10;if ((timeLeft &lt;= 0)) {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
