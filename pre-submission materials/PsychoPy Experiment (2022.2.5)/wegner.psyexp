        <Param val="items = [instructions[3], instructions[4], instructions[5], instructions[6]];&amp;#10;util.shuffle(items);&amp;#10;util.shuffle(items1);&amp;#10;util.shuffle(items2);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="items = [instructions[3], instructions[4], instructions[5],instructions[6]]&amp;#10;shuffle(items)&amp;#10;shuffle(items1)&amp;#10;shuffle(items2)&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
