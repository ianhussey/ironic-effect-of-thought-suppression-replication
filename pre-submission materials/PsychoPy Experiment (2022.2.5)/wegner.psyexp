    <Routine name="start">
      <CodeComponent name="code">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="userows=&quot;&quot;&amp;#10;&amp;#10;langOffset = 0&amp;#10;if expInfo['Country'] == 'ID':&amp;#10;    langOffset = 16&amp;#10;elif expInfo['Country'] == 'CN':&amp;#10;    langOffset = 32&amp;#10;elif expInfo['Country'] == 'IT':&amp;#10;    langOffset = 48&amp;#10;elif expInfo['Country'] == 'FR':&amp;#10;    langOffset = 64&amp;#10;elif expInfo['Country'] == 'TR':&amp;#10;    langOffset = 80&amp;#10;elif expInfo['Country'] == 'US':&amp;#10;    langOffset = 96&amp;#10;elif expInfo['Country'] == 'DE':&amp;#10;    langOffset = 112&amp;#10;elif expInfo['Country'] == 'PT':&amp;#10;    langOffset = 128&amp;#10;elif expInfo['Country'] == 'RO':&amp;#10;    langOffset = 144&amp;#10;elif expInfo['Country'] == 'NL':&amp;#10;    langOffset = 160&amp;#10;&amp;#10;if expInfo['targets'] == '1':&amp;#10;    useRows = str(langOffset) + &quot;:&quot; + str(langOffset+8)&amp;#10;elif expInfo['targets'] == '2':&amp;#10;    useRows = str(langOffset+8) + &quot;:&quot; + str(langOffset+16)&amp;#10;&amp;#10;fillerRows = str(langOffset) + &quot;:&quot; + str(langOffset+8)&amp;#10;instructRows = str(langOffset+8) + &quot;:&quot; + str(langOffset+15)&amp;#10;&amp;#10;countFrom = []&amp;#10;if expInfo['order'] == '1':&amp;#10;    countFrom = [3,10]&amp;#10;elif expInfo['order'] == '2':&amp;#10;    countFrom = [10,3]&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="userows = &quot;&quot;;&amp;#10;langOffset = 0;&amp;#10;if ((expInfo[&quot;Country&quot;] === &quot;ID&quot;)) {&amp;#10;    langOffset = 16;&amp;#10;} else {&amp;#10;    if ((expInfo[&quot;Country&quot;] === &quot;CN&quot;)) {&amp;#10;        langOffset = 32;&amp;#10;    } else {&amp;#10;        if ((expInfo[&quot;Country&quot;] === &quot;IT&quot;)) {&amp;#10;            langOffset = 48;&amp;#10;        } else {&amp;#10;            if ((expInfo[&quot;Country&quot;] === &quot;FR&quot;)) {&amp;#10;                langOffset = 64;&amp;#10;            } else {&amp;#10;                if ((expInfo[&quot;Country&quot;] === &quot;TR&quot;)) {&amp;#10;                    langOffset = 80;&amp;#10;                } else {&amp;#10;                    if ((expInfo[&quot;Country&quot;] === &quot;US&quot;)) {&amp;#10;                        langOffset = 96;&amp;#10;                    } else {&amp;#10;                        if ((expInfo[&quot;Country&quot;] === &quot;DE&quot;)) {&amp;#10;                            langOffset = 112;&amp;#10;                        } else {&amp;#10;                            if ((expInfo[&quot;Country&quot;] === &quot;PT&quot;)) {&amp;#10;                                langOffset = 128;&amp;#10;                            } else {&amp;#10;                                if ((expInfo[&quot;Country&quot;] === &quot;RO&quot;)) {&amp;#10;                                    langOffset = 144;&amp;#10;                                } else {&amp;#10;                                    if ((expInfo[&quot;Country&quot;] === &quot;NL&quot;)) {&amp;#10;                                        langOffset = 160;&amp;#10;                                    }&amp;#10;                                }&amp;#10;                            }&amp;#10;                        }&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;if ((expInfo[&quot;targets&quot;] === &quot;1&quot;)) {&amp;#10;    useRows = ((langOffset.toString() + &quot;:&quot;) + (langOffset + 8).toString());&amp;#10;} else {&amp;#10;    if ((expInfo[&quot;targets&quot;] === &quot;2&quot;)) {&amp;#10;        useRows = (((langOffset + 8).toString() + &quot;:&quot;) + (langOffset + 16).toString());&amp;#10;    }&amp;#10;}&amp;#10;fillerRows = ((langOffset.toString() + &quot;:&quot;) + (langOffset + 8).toString());&amp;#10;instructRows = (((langOffset + 8).toString() + &quot;:&quot;) + (langOffset + 15).toString());&amp;#10;countFrom = [];&amp;#10;if ((expInfo[&quot;order&quot;] === &quot;1&quot;)) {&amp;#10;    countFrom = [3, 10];&amp;#10;} else {&amp;#10;    if ((expInfo[&quot;order&quot;] === &quot;2&quot;)) {&amp;#10;        countFrom = [10, 3];&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
